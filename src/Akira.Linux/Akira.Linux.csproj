<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Akira.Linux</RootNamespace>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IsAotCompatible>true</IsAotCompatible>
  </PropertyGroup>

  <PropertyGroup>
    <PackageId>Akira.Linux</PackageId>
    <Version>0.1.2-alpha</Version>
    <Authors>Corderro Artz</Authors>
    <Description>Linux /proc and /sys based snapshot providers for the Akira system state library.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageTags>akira;linux;proc;sys;system;snapshot;hardware;diagnostics</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <IsPackable>true</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" />
    <ProjectReference Include="..\Akira\Akira.csproj" />
  </ItemGroup>

</Project>
